	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "BoringSSL_fipsmodule"
	Target.BaseFileName "fipsmodule"
	Target.ObjectLibrary true
	%Group "crypto"
	{
		%File `@('../../../../External/boringssl'->MakeAbsolute())/crypto/fipsmodule/bcm.c`
		{
			Compile.Type "C"
		}
	}
	%Group "gen"
	{
