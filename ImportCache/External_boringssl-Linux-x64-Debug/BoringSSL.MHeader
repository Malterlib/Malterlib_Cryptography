%Target "Lib_BoringSSL_ssl"
{
	Compile
	{
		!!Compile.Type "C++"
		SearchPath += [
			`@('../../../../External/boringssl'->MakeAbsolute())/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BORINGSSL_DISPATCH_TEST",
			"BORINGSSL_IMPLEMENTATION"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "BoringSSL_ssl"
	Target.BaseFileName "ssl"
	%Group "ssl"
	{
		%File `@('../../../../External/boringssl'->MakeAbsolute())/ssl/bio_ssl.cc`
