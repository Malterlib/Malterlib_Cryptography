Property.CMakeOutputPath_BoringSSL: string = `@('.'->MakeAbsolute())`->MakeAbsolute()
%Target "Tool_BoringSSL_boringssl_prefix_symbols"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "BoringSSL_boringssl_prefix_symbols"
	Target.BaseFileName "boringssl_prefix_symbols"
}
%Target "Lib_BoringSSL_boringssl_gtest"
{
	Compile
	{
		!!Compile.Type "C++"
		SearchPath += [
			`@('../../../../External/boringssl'->MakeAbsolute())/third_party/googletest/googlemock/include`->MakeAbsolute(),
			`@('../../../../External/boringssl'->MakeAbsolute())/third_party/googletest/googletest/include`->MakeAbsolute(),
			`@('../../../../External/boringssl'->MakeAbsolute())/third_party/googletest/googlemock`->MakeAbsolute(),
			`@('../../../../External/boringssl'->MakeAbsolute())/third_party/googletest/googletest`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BORINGSSL_DISPATCH_TEST",
			"BORINGSSL_IMPLEMENTATION"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "BoringSSL_boringssl_gtest"
	Target.BaseFileName "boringssl_gtest"
	%Group "third_party"
	{
		%Group "googletest"
		{
			%Group "googlemock"
			{
				%Group "src"
				{
					%File `@('../../../../External/boringssl'->MakeAbsolute())/third_party/googletest/googlemock/src/gmock-all.cc`
					{
						Compile.Type "C++"
					}
				}
			}
			%Group "googletest"
			{
				%Group "src"
				{
					%File `@('../../../../External/boringssl'->MakeAbsolute())/third_party/googletest/googletest/src/gtest-all.cc`
					{
						Compile.Type "C++"
					}
				}
			}
		}
	}
}
%Target "Tool_BoringSSL_all_tests"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "BoringSSL_all_tests"
	Target.BaseFileName "all_tests"
	%Dependency "Com_BoringSSL_crypto_test"
	{
		Dependency.Link false
	}
	%Dependency "Com_BoringSSL_decrepit_test"
	{
		Dependency.Link false
	}
	%Dependency "Com_BoringSSL_pki_test"
	{
		Dependency.Link false
	}
	%Dependency "Com_BoringSSL_ssl_test"
	{
		Dependency.Link false
	}
	%Dependency "Com_BoringSSL_urandom_test"
	{
		Dependency.Link false
	}
}
%Target "Lib_BoringSSL_fipsmodule"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../External/boringssl'->MakeAbsolute())/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BORINGSSL_DISPATCH_TEST",
			"BORINGSSL_IMPLEMENTATION"
		]
	}
	Compile
	{
		!!Compile.Type "Assembler"
		SearchPath += [
			`@('../../../../External/boringssl'->MakeAbsolute())/include`->MakeAbsolute()
