%Target "Lib_BoringSSL_crypto"
{
	Compile
	{
		!!Compile.Type "C++"
		SearchPath += [
			`@('../../../../External/boringssl'->MakeAbsolute())/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BORINGSSL_DISPATCH_TEST",
			"BORINGSSL_IMPLEMENTATION"
		]
	}
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../External/boringssl'->MakeAbsolute())/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BORINGSSL_DISPATCH_TEST",
			"BORINGSSL_IMPLEMENTATION"
		]
	}
	Compile
	{
		!!Compile.Type "Assembler"
		SearchPath += [
			`@('../../../../External/boringssl'->MakeAbsolute())/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BORINGSSL_DISPATCH_TEST",
			"BORINGSSL_IMPLEMENTATION"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "BoringSSL_crypto"
	Target.BaseFileName "crypto"
	%Group "crypto"
	{
		%Group "asn1"
		{
			%File `@('../../../../External/boringssl'->MakeAbsolute())/crypto/asn1/a_bitstr.c`
			{
				Compile.Type "C"
			}
			%File `@('../../../../External/boringssl'->MakeAbsolute())/crypto/asn1/a_bool.c`
			{
				Compile.Type "C"
			}
			%File `@('../../../../External/boringssl'->MakeAbsolute())/crypto/asn1/a_d2i_fp.c`
			{
				Compile.Type "C"
			}
			%File `@('../../../../External/boringssl'->MakeAbsolute())/crypto/asn1/a_dup.c`
			{
				Compile.Type "C"
			}
			%File `@('../../../../External/boringssl'->MakeAbsolute())/crypto/asn1/a_gentm.c`
			{
				Compile.Type "C"
			}
			%File `@('../../../../External/boringssl'->MakeAbsolute())/crypto/asn1/a_i2d_fp.c`
			{
				Compile.Type "C"
			}
