	%Dependency "Lib_BoringSSL_crypto"
	{
		Dependency.Indirect true
	}
	%Dependency "Lib_BoringSSL_ssl"
	{
		Dependency.Indirect true
	}
}
%Target "Com_BoringSSL_decrepit_test"
{
	Compile
	{
		!!Compile.Type "C++"
		SearchPath += [
			`@('../../../../External/boringssl'->MakeAbsolute())/third_party/googletest/include`->MakeAbsolute(),
			`@('../../../../External/boringssl'->MakeAbsolute())/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BORINGSSL_DISPATCH_TEST",
			"BORINGSSL_IMPLEMENTATION"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "BoringSSL_decrepit_test"
	Target.BaseFileName "decrepit_test"
	%Group "decrepit"
