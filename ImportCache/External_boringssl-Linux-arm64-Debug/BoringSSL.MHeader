Property.CMakeOutputPath_BoringSSL: string = `@('.'->MakeAbsolute())`->MakeAbsolute()
%Target "Tool_BoringSSL_global_target"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "BoringSSL_global_target"
	Target.BaseFileName "global_target"
}
%Target "Lib_BoringSSL_boringssl_gtest"
{
	Compile
	{
		!!Compile.Type "C++"
		SearchPath += [
			`@('../../../../External/boringssl'->MakeAbsolute())/third_party/googletest`->MakeAbsolute(),
			`@('../../../../External/boringssl'->MakeAbsolute())/third_party/googletest/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BORINGSSL_DISPATCH_TEST",
			"BORINGSSL_IMPLEMENTATION"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "BoringSSL_boringssl_gtest"
	Target.BaseFileName "boringssl_gtest"
	%Group "third_party"
	{
		%File `@('../../../../External/boringssl'->MakeAbsolute())/third_party/googletest/src/gtest-all.cc`
		{
			Compile.Type "C++"
		}
	}
}
%Target "Tool_BoringSSL_all_tests"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "BoringSSL_all_tests"
	Target.BaseFileName "all_tests"
	%Dependency "Com_BoringSSL_crypto_test"
	{
		Dependency.Link false
	}
	%Dependency "Com_BoringSSL_decrepit_test"
	{
		Dependency.Link false
	}
	%Dependency "Com_BoringSSL_ssl_test"
	{
		Dependency.Link false
	}
	%Dependency "Com_BoringSSL_urandom_test"
	{
		Dependency.Link false
	}
}
%Target "Tool_BoringSSL_fips_specific_tests_if_any"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "BoringSSL_fips_specific_tests_if_any"
	Target.BaseFileName "fips_specific_tests_if_any"
}
%Target "Tool_BoringSSL_run_tests"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/BoringSSL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "BoringSSL_run_tests"
	Target.BaseFileName "run_tests"
	%Group "Linux"
	{
		%Group "arm64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "CMakeFiles"
				{
					%File `@('.'->MakeAbsolute())/CMakeFiles/run_tests.rule`
					{
						Compile
						{
							Custom_CommandLine `go run util/all_tests.go -build-dir @(`@('.'->MakeAbsolute())`->MakeAbsolute()->EscapeHost()) && cd ssl/test/runner && go test -shim-path @(`@('.'->MakeAbsolute())/ssl/test/bssl_shim`->MakeAbsolute()->EscapeHost()) -handshaker-path @(`@('.'->MakeAbsolute())/ssl/test/handshaker`->MakeAbsolute()->EscapeHost())`
							AllowNonExisting true
							Disabled false
							Custom_WorkingDirectory `@('../../../../External/boringssl'->MakeAbsolute())`->MakeAbsolute()
							Custom_Outputs []
							Custom_Inputs [
								`@('.'->MakeAbsolute())/ssl/test/bssl_shim`->MakeAbsolute(),
								`@('.'->MakeAbsolute())/ssl/test/handshaker`->MakeAbsolute()
							]
						}
					}
				}
			}
		}
	}
	%Dependency "Tool_BoringSSL_all_tests"
	{
		Dependency.Link false
	}
	%Dependency "Com_BoringSSL_bssl_shim"
	{
		Dependency.Link false
	}
	%Dependency "Tool_BoringSSL_fips_specific_tests_if_any"
	{
		Dependency.Link false
	}
	%Dependency "Com_BoringSSL_handshaker"
	{
		Dependency.Link false
	}
}
%Target "Lib_BoringSSL_crypto"
{
	Compile
	{
		!!Compile.Type "C++"
