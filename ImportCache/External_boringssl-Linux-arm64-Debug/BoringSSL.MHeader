			}
		}
		%Group "cfb"
		{
			%File `@('../../../../External/boringssl'->MakeAbsolute())/decrepit/cfb/cfb_test.cc`
			{
				Compile.Type "C++"
			}
		}
		%Group "evp"
		{
			%File `@('../../../../External/boringssl'->MakeAbsolute())/decrepit/evp/evp_test.cc`
			{
				Compile.Type "C++"
			}
		}
		%Group "ripemd"
		{
