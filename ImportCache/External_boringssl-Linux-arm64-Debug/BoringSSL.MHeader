	%Group "Linux"
	{
		%Group "arm64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "crypto"
				{
					%File `@(CMakeIntermediateDirectory)/External_boringssl/crypto/err_data.c`->MakeAbsolute()
					{
						Compile.AllowNonExisting true
						Compile.Type "C"
					}
					%Group "chacha"
					{
						%File `@(CMakeIntermediateDirectory)/External_boringssl/crypto/chacha/chacha-armv8.S`->MakeAbsolute()
						{
							Compile.AllowNonExisting true
							Compile.Type "Assembler"
						}
						%File `@('.'->MakeAbsolute())/crypto/chacha/chacha-armv8.S.rule`
						{
							Compile
							{
								Custom_CommandLine `MToolCMake -E make_directory @(`@('.'->MakeAbsolute())/crypto/chacha`->MakeAbsolute()->EscapeHost()) && perl @(`@('../../../../External/boringssl'->MakeAbsolute())/crypto/chacha/asm/chacha-armv8.pl`->MakeAbsolute()->EscapeHost()) linux64 @(`@(CMakeIntermediateDirectory)/External_boringssl/crypto/chacha/chacha-armv8.S`->MakeAbsolute()->EscapeHost())`
								AllowNonExisting true
								Custom_WorkingDirectory `@('.'->MakeAbsolute())/crypto`->MakeAbsolute()
								Custom_Outputs [
									`@(CMakeIntermediateDirectory)/External_boringssl/crypto/chacha/chacha-armv8.S`->MakeAbsolute()
								]
								Custom_Inputs [
									`@('../../../../External/boringssl'->MakeAbsolute())/crypto/chacha/asm/chacha-armv8.pl`->MakeAbsolute(),
									`@('../../../../External/boringssl'->MakeAbsolute())/crypto/perlasm/arm-xlate.pl`->MakeAbsolute(),
									`@('../../../../External/boringssl'->MakeAbsolute())/crypto/perlasm/ppc-xlate.pl`->MakeAbsolute(),
									`@('../../../../External/boringssl'->MakeAbsolute())/crypto/perlasm/x86_64-xlate.pl`->MakeAbsolute(),
									`@('../../../../External/boringssl'->MakeAbsolute())/crypto/perlasm/x86asm.pl`->MakeAbsolute(),
									`@('../../../../External/boringssl'->MakeAbsolute())/crypto/perlasm/x86gas.pl`->MakeAbsolute(),
									`@('../../../../External/boringssl'->MakeAbsolute())/crypto/perlasm/x86masm.pl`->MakeAbsolute(),
									`@('../../../../External/boringssl'->MakeAbsolute())/crypto/perlasm/x86nasm.pl`->MakeAbsolute()
								]
							}
						}
					}
					%Group "test"
					{
						%File `@(CMakeIntermediateDirectory)/External_boringssl/crypto/test/trampoline-armv8.S`->MakeAbsolute()
						{
							Compile.AllowNonExisting true
							Compile.Type "Assembler"
						}
						%File `@('.'->MakeAbsolute())/crypto/test/trampoline-armv8.S.rule`
						{
							Compile
							{
